        "format:check": "prettier --check .",
        "test": "vitest run"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.0.0",
        "@types/node": "^22.0.0",
        "prettier": "^3.5.3",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^4.1.6",
        "wrangler": "^4.0.0"
    }
}
