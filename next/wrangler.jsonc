{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "campwatch",
    "main": ".open-next/worker.js",
    "compatibility_date": "2026-05-14",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
    },
    "kv_namespaces": [
        {
            "binding": "SUBSCRIBERS",
            "id": "41a67a8b06044ee38f0bf22cfbcc069d"
        }
    ],
    "observability": {
        "enabled": true
    }
}
